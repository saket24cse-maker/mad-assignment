<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/accelerometer_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Accelerometer Sensor"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/accelerometer_data"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="X: 0, Y: 0, Z: 0"
        android:paddingBottom="16dp" />

    <TextView
        android:id="@+id/light_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Light Sensor"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/light_data"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Luminosity: 0 lx"
        android:paddingBottom="16dp" />

    <TextView
        android:id="@+id/proximity_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Proximity Sensor"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/proximity_data"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Distance: 0 cm" />

</LinearLayout>